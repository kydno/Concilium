# Inception Labs API key (server-side only — never expose to the browser)
INCEPTION_API_KEY=your_inception_api_key_here

# Optional fallback key — used when the primary is unset, or on 401/402/429 from Inception
INCEPTION_API_KEY_FALLBACK=your_fallback_inception_api_key_here

# Neon Postgres (optional — enables sidebar persistence). Provision via Neon MCP: https://mcp.neon.tech/mcp
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Max context tokens before hard stop (default 128000)
CONTEXT_LIMIT_TOKENS=128000
